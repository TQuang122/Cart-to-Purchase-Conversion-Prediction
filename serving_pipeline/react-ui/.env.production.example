# Frontend API base URL for production builds (Vercel)
# IMPORTANT: VITE_API_BASE_URL is injected at build time by Vite.
# Set this variable in Vercel Project Settings -> Environment Variables
# for Production and Preview.
#
# CURRENT ENDPOINT (ephemeral trycloudflare - URL changes on restart):
VITE_API_BASE_URL=https://treat-nylon-exact-defense.trycloudflare.com
#
# To auto-sync on tunnel restart, run:
#   AUTO_UPDATE_VERCEL=true scripts/k8s-tunnel.sh start
# Or use daemon mode:
#   AUTO_UPDATE_VERCEL=true scripts/k8s-tunnel.sh daemon-start
#
# For permanent fixed URL, set up named Cloudflare Tunnel with domain.
