<mxfile host="app.diagrams.net">
  <diagram name="Data Pipeline and Feature Engineering" id="data-pipeline">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t3" value="Data Pipeline and Feature Engineering - Detailed Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#1A1A2E;" vertex="1" parent="1"><mxGeometry x="400" y="10" width="800" height="40" as="geometry"/></mxCell>
        <!-- STEP 1: RAW DATA -->
        <mxCell id="s1_label" value="[1. RAW DATA]" style="text;html=1;strokeColor=#455A64;fillColor=#ECEFF1;fontSize=13;fontStyle=1;fontColor=#455A64;" vertex="1" parent="1"><mxGeometry x="20" y="70" width="120" height="25" as="geometry"/></mxCell>
        <mxCell id="s1_kaggle" value="2019-Nov.csv.gz&#xa;(Kaggle eCommerce)&#xa;&#xa;285M+ events&#xa;Oct 2019 - Apr 2020&#xa;&#xa;Open CDP Project" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontColor=#263238;fontSize=10;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="100" width="200" height="130" as="geometry"/></mxCell>
        <mxCell id="s1_schema" value="Raw Schema&#xa;----------&#xa;event_time (timestamp)&#xa;event_type&#xa;  (view/cart/purchase)&#xa;product_id (long)&#xa;category_id (long)&#xa;category_code (str)&#xa;brand (str)&#xa;price (double)&#xa;user_id (long)&#xa;user_session (str)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;fontColor=#424242;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="245" width="160" height="155" as="geometry"/></mxCell>
        <!-- STEP 2: PREPROCESSING -->
        <mxCell id="s2_label" value="[2. PREPROCESSING]" style="text;html=1;strokeColor=#1565C0;fillColor=#E3F2FD;fontSize=13;fontStyle=1;fontColor=#0D47A1;" vertex="1" parent="1"><mxGeometry x="280" y="70" width="160" height="25" as="geometry"/></mxCell>
        <mxCell id="s2_spark" value="preprocessed_pyspark_001.ipynb&#xa;(PySpark)&#xa;&#xa;- Filter event_type&#xa;- Handle missing brands&#xa;- Split category_code&#xa;- Extract timestamps&#xa;- Aggregate sessions&#xa;- Create target label&#xa;&#xa;67.5M rows" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="280" y="100" width="200" height="180" as="geometry"/></mxCell>
        <mxCell id="s2_target" value="Target Definition&#xa;---------------&#xa;Unit: cart event&#xa;&#xa;is_purchased = 1&#xa;  if same user_id +&#xa;  product_id purchased&#xa;  in same session&#xa;&#xa;is_purchased = 0&#xa;  otherwise (abandoned cart)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontColor=#E65100;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="280" y="295" width="200" height="115" as="geometry"/></mxCell>
        <!-- STEP 3: FEATURE ENGINEERING -->
        <mxCell id="s3_label" value="[3. FEATURE ENGINEERING V2]" style="text;html=1;strokeColor=#2E7D32;fillColor=#E8F5E9;fontSize=13;fontStyle=1;fontColor=#1B5E20;" vertex="1" parent="1"><mxGeometry x="540" y="70" width="220" height="25" as="geometry"/></mxCell>
        <mxCell id="s3_fe" value="feature_engineering_v2_optimized.py&#xa;(PySpark)&#xa;&#xa;User Aggregates&#xa;Product Aggregates&#xa;Brand Aggregates&#xa;Price Comparisons&#xa;Temporal Features" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=11;align=center;arcSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="540" y="100" width="210" height="120" as="geometry"/></mxCell>
        <mxCell id="fg_user" value="User Aggregates&#xa;---------------&#xa;- user_total_events&#xa;- user_total_views&#xa;- user_total_carts&#xa;- user_total_purchases&#xa;- user_view_to_cart_rate&#xa;- user_cart_to_purchase_rate&#xa;- user_avg_purchase_price&#xa;- user_unique_products&#xa;- user_unique_categories" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="540" y="230" width="140" height="170" as="geometry"/></mxCell>
        <mxCell id="fg_product" value="Product Aggregates&#xa;-----------------&#xa;- product_total_events&#xa;- product_total_views&#xa;- product_total_carts&#xa;- product_total_purchases&#xa;- product_view_to_cart_rate&#xa;- product_cart_to_purchase_rate&#xa;- product_unique_buyers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="690" y="230" width="140" height="130" as="geometry"/></mxCell>
        <mxCell id="fg_brand" value="Brand/Price&#xa;-----------&#xa;- brand_purchase_rate&#xa;- price_vs_user_avg&#xa;- price_vs_category_avg" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontColor=#BF360C;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="540" y="415" width="140" height="75" as="geometry"/></mxCell>
        <mxCell id="fg_temporal" value="Temporal&#xa;---------&#xa;- event_weekday&#xa;- event_hour&#xa;- activity_count" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontColor=#4A148C;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="690" y="375" width="140" height="75" as="geometry"/></mxCell>
        <!-- STEP 4: OUTPUT -->
        <mxCell id="s4_label" value="[4. OUTPUT DATASET]" style="text;html=1;strokeColor=#6A1B9A;fillColor=#EDE7F6;fontSize=13;fontStyle=1;fontColor=#4A148C;" vertex="1" parent="1"><mxGeometry x="850" y="70" width="150" height="25" as="geometry"/></mxCell>
        <mxCell id="s4_csv" value="df_processed_fe_optimized_v2.csv&#xa;&#xa;2,929,997 rows&#xa;31 columns&#xa;&#xa;Memory: ~1645 MB" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#6A1B9A;strokeColor=#4A148C;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="850" y="100" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="s4_parquet" value="Parquet (Feast-backed)&#xa;&#xa;train.parquet&#xa;test.parquet&#xa;user_features.parquet&#xa;product_features.parquet" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#4A148C;strokeColor=#311B92;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="850" y="205" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="s4_schema" value="Final Schema (31 cols)&#xa;--------------------&#xa;IDs: user_id, product_id&#xa;Temporal: event_timestamp,&#xa;  created_timestamp&#xa;Categorical: category_level1,&#xa;  level2, brand&#xa;Temporal: event_weekday,&#xa;  event_hour&#xa;Price: price&#xa;User agg (10): *_events/views/&#xa;  carts/purchases, *_rate,&#xa;  avg_price, unique_*&#xa;Product agg (7): *_events/views/&#xa;  carts/purchases, *_rate,&#xa;  unique_buyers&#xa;Brand/Price (3):&#xa;  brand_purchase_rate,&#xa;  price_vs_user_avg/category_avg&#xa;Target: is_purchased" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontColor=#4A148C;fontSize=8;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="850" y="305" width="200" height="185" as="geometry"/></mxCell>
        <!-- STEP 5: TRAIN/TEST SPLIT -->
        <mxCell id="s5_label" value="[5. TRAIN/TEST SPLIT]" style="text;html=1;strokeColor=#E65100;fillColor=#FFF3E0;fontSize=13;fontStyle=1;fontColor=#BF360C;" vertex="1" parent="1"><mxGeometry x="1080" y="70" width="170" height="25" as="geometry"/></mxCell>
        <mxCell id="s5_split" value="split_train_test.py&#xa;&#xa;stratified by is_purchased&#xa;80/20 split&#xa;&#xa;Ensures all category&#xa;values appear in train&#xa;&#xa;After dropna + dedup:" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontColor=#BF360C;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1080" y="100" width="160" height="140" as="geometry"/></mxCell>
        <mxCell id="s5_train" value="Train Set&#xa;--------&#xa;2,312,572 rows&#xa;(80%)&#xa;&#xa;After dropna + dedup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E65100;strokeColor=#BF360C;fontColor=#FFFFFF;fontStyle=1;fontSize=10;align=center;arcSize=15;" vertex="1" parent="1"><mxGeometry x="1080" y="255" width="100" height="90" as="geometry"/></mxCell>
        <mxCell id="s5_test" value="Test Set&#xa;-------&#xa;578,143 rows&#xa;(20%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BF360C;strokeColor=#870000;fontColor=#FFFFFF;fontStyle=1;fontSize=10;align=center;arcSize=15;" vertex="1" parent="1"><mxGeometry x="1190" y="255" width="100" height="70" as="geometry"/></mxCell>
        <!-- STEP 6: TRAINING -->
        <mxCell id="s6_label" value="[6. MODEL TRAINING]" style="text;html=1;strokeColor=#F57F17;fillColor=#FFFDE7;fontSize=13;fontStyle=1;fontColor=#F9A825;" vertex="1" parent="1"><mxGeometry x="1320" y="70" width="150" height="25" as="geometry"/></mxCell>
        <mxCell id="s6_train" value="train.py&#xa;&#xa;Target Encoding&#xa;(smoothing=20)&#xa;&#xa;OneHotEncoding&#xa;(3 categoricals)&#xa;&#xa;Final: 196 columns&#xa;(after encoding)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F57F17;fontColor=#E65100;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1320" y="100" width="150" height="130" as="geometry"/></mxCell>
        <mxCell id="s6_xgb" value="XGBoost&#xa;-------&#xa;500 estimators&#xa;max_depth=8&#xa;learning_rate=0.05&#xa;scale_pos_weight=2.856&#xa;&#xa;F1@0.525: 0.7381&#xa;AUC: 0.9312" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F57F17;strokeColor=#E65100;fontColor=#FFFFFF;fontStyle=1;fontSize=10;align=center;arcSize=15;" vertex="1" parent="1"><mxGeometry x="1320" y="245" width="150" height="110" as="geometry"/></mxCell>
        <mxCell id="s6_hpo" value="hpo.py&#xa;(Optuna)&#xa;&#xa;1M samples&#xa;5-fold CV&#xa;100 trials" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#F9A825;fontColor=#BF360C;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1320" y="370" width="80" height="65" as="geometry"/></mxCell>
        <mxCell id="s6_mlflow" value="MLflow&#xa;&#xa;metrics logging&#xa;artifacts&#xa;registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6F00;strokeColor=#E65100;fontColor=#FFFFFF;fontSize=10;align=center;arcSize=15;" vertex="1" parent="1"><mxGeometry x="1320" y="450" width="75" height="60" as="geometry"/></mxCell>
        <mxCell id="s6_minio" value="MinIO S3&#xa;&#xa;model.pkl&#xa;artifacts" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#795548;strokeColor=#4E342E;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="1320" y="525" width="75" height="55" as="geometry"/></mxCell>
        <!-- STEP 7: SERVING -->
        <mxCell id="s7_label" value="[7. SERVING AND INFERENCE]" style="text;html=1;strokeColor=#00838F;fillColor=#E0F7FA;fontSize=13;fontStyle=1;fontColor=#006064;" vertex="1" parent="1"><mxGeometry x="20" y="440" width="170" height="25" as="geometry"/></mxCell>
        <mxCell id="s7_serving" value="BinaryClassifierWrapper&#xa;(Serving)&#xa;&#xa;joblib.load(model.pkl)&#xa;  -&gt; BinaryClassifierWrapper&#xa;  -&gt; .model (XGBClassifier)&#xa;  -&gt; .feature_encoders&#xa;  -&gt; .feature_names&#xa;&#xa;Threshold: 0.525&#xa;Model URI from MLflow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00838F;fontColor=#006064;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="475" width="200" height="155" as="geometry"/></mxCell>
        <mxCell id="s7_enc" value="encoders.json&#xa;------------&#xa;Target encoding&#xa;3 categorical features&#xa;global_mean=0.1306&#xa;Smoothing=20" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#00838F;strokeColor=#004D40;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="20" y="645" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="s7_input" value="3 Inference Input Tiers&#xa;---------------------&#xa;&#xa;Tier 1: /predict/raw&#xa;  26 features (full)&#xa;  Quality: A&#xa;&#xa;Tier 2: /predict/raw-lite&#xa;  14 features + 12 auto-derived&#xa;  Quality: B-D&#xa;&#xa;Tier 3: /predict/feast&#xa;  user_id + product_id only&#xa;  Quality: A" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#B2EBF2;strokeColor=#00ACC1;fontColor=#006064;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="210" y="475" width="200" height="170" as="geometry"/></mxCell>
        <mxCell id="s7_output" value="Prediction Response&#xa;--------------------&#xa;&#xa;is_purchased: 0|1&#xa;probability&#xa;decision_threshold&#xa;feature_contributions&#xa;  (SHAP/tree SHAP)&#xa;feature_quality&#xa;  (score, grade A-D)&#xa;explainability&#xa;  (top_signals)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#1A237E;fontColor=#1A237E;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="210" y="660" width="200" height="140" as="geometry"/></mxCell>
        <mxCell id="s7_fastapi" value="FastAPI&#xa;(serving_pipeline/)&#xa;&#xa;port: 8000 / 18000&#xa;conda: propensity_mlops&#xa;&#xa;/predict/*&#xa;/chat/*&#xa;/dataset/*&#xa;/model/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00838F;strokeColor=#006064;fontColor=#FFFFFF;fontStyle=1;fontSize=10;align=center;arcSize=15;" vertex="1" parent="1"><mxGeometry x="440" y="475" width="150" height="100" as="geometry"/></mxCell>
        <mxCell id="s7_kind" value="KinD K8s&#xa;--------&#xa;2 replicas&#xa;image: ctpserving:v9&#xa;port: 18000" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#1A237E;fontColor=#1A237E;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="440" y="590" width="100" height="65" as="geometry"/></mxCell>
        <mxCell id="s7_docker" value="Docker&#xa;Compose&#xa;--------&#xa;local dev&#xa;uvicorn&#xa;:8000" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="550" y="590" width="100" height="65" as="geometry"/></mxCell>
        <mxCell id="s7_airflow" value="Airflow DAGs&#xa;-------------&#xa;cart_to_purchase_e2e&#xa;cart_to_purchase_k8s&#xa;ctp_e2e_tabicl_dag" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0277BD;strokeColor=#01579B;fontColor=#FFFFFF;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="440" y="670" width="150" height="75" as="geometry"/></mxCell>
        <!-- LEGEND -->
        <mxCell id="leg3" value="Legend&#xa;------&#xa;Solid = primary flow&#xa;Dashed = config/lookup&#xa;Cylinder = storage&#xa;Color = pipeline stage" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;fontColor=#424242;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="660" y="510" width="140" height="75" as="geometry"/></mxCell>
        <!-- ARROWS -->
        <mxCell id="a1_2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2.5;strokeColor=#455A64;endArrow=classic;endFill=1;" edge="1" parent="1" source="s1_kaggle" target="s2_spark"><mxGeometry relative="1" as="geometry"/></mxCell>
