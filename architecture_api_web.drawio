        <mxCell id="bcw" value="BinaryClassifierWrapper&#xa;(MLflow loaded)&#xa;&#xa;joblib.load()&#xa;  -&gt; BinaryClassifierWrapper&#xa;  -&gt; .model (XGBClassifier)&#xa;  -&gt; .feature_encoders&#xa;  -&gt; .feature_names&#xa;&#xa;predict() = SHAP contributions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontColor=#BF360C;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="560" y="100" width="200" height="160" as="geometry"/></mxCell>
        <mxCell id="encoders_box" value="encoders.json&#xa;(Target Encoding)&#xa;----------------&#xa;- brand: 113 values&#xa;- category_level1: 10&#xa;- category_level2: 48&#xa;&#xa;global_mean=0.1306" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#BF360C;strokeColor=#870000;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="560" y="280" width="170" height="70" as="geometry"/></mxCell>
