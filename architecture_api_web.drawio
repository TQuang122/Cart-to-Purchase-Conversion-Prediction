        <mxCell id="input_raw" value="1. Raw Features&#xa;-----------&#xa;26 features&#xa;(user + product + brand +&#xa; temporal + price)&#xa;&#xa;Quality: Grade A&#xa;API: POST /predict/raw" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="600" width="160" height="120" as="geometry"/></mxCell>
        <mxCell id="input_lite" value="2. Raw-Lite&#xa;----------&#xa;14 features&#xa;(12 features auto-derived)&#xa;&#xa;Quality: Grade B-D&#xa;API: POST /predict/raw-lite&#xa;_preprocess_raw_lite()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontColor=#E65100;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="195" y="600" width="160" height="120" as="geometry"/></mxCell>
        <mxCell id="input_feast" value="3. Feast Lookup&#xa;-------------&#xa;user_id + product_id&#xa;(features fetched from&#xa;parquet feature store)&#xa;&#xa;Quality: Grade A&#xa;API: POST /predict/feast" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7B1FA2;fontColor=#4A148C;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="370" y="600" width="160" height="120" as="geometry"/></mxCell>
