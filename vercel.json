{
  "buildCommand": "cd serving_pipeline/react-ui && npm install && npm run build",
  "outputDirectory": "serving_pipeline/react-ui/dist",
  "installCommand": "cd serving_pipeline/react-ui && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!assets/|favicon-c2p\.svg|robots\.txt|sitemap\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
